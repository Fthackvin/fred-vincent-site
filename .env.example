# Copy to .env for local development. Do not commit .env.
# Vercel reads these from Project Settings → Environment Variables.

# Formspree endpoint URL — used by /api/submit-problem.js to proxy
# the "Send me a problem" form. The form submits to /api/submit-problem
# on the page; the serverless function forwards to this URL.
FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Vercel Deploy Hook URL — used by /api/cron-rebuild.js to trigger
# a daily rebuild that re-runs the RSS fetch.
DEPLOY_HOOK_URL=

# Optional — if set, /api/cron-rebuild requires Authorization: Bearer <secret>
CRON_SECRET=
